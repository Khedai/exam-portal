# Server port (defaults to 5000)
PORT=5000

# Secret token for teacher to reset student logins (set this to a strong random value)
TEACHER_SECRET=change-me-to-a-secure-random-string

# Client: set VITE_API_URL in client/.env.production
# For monolith deploy (Express serves frontend), leave it as /api
# For decoupled deploy, set it to your server URL, e.g. https://my-api.onrender.com/api