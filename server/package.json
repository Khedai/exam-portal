{
  "name": "server",
  "version": "1.0.0",
  "description": "Exam Portal API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && npm run copy-data",
    "copy-data": "node -e \"const fs=require('fs'),p=require('path');const d=p.join('dist','data');if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});['exams.json','submissions.json'].forEach(f=>{const s=p.join('src','data',f),t=p.join(d,f);if(!fs.existsSync(t)&&fs.existsSync(s))fs.copyFileSync(s,t)})\"",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
